{
  "POST /billing/web-session": {
    "headers": {
      "Authorization": "Bearer <token>"
    },
    "request": {
      "plan": "monthly|family",
      "returnUrl": "string"
    },
    "response_200": {
      "checkoutUrl": "https://pay.your-domain.example/session/abc123",
      "sessionId": "sess_123"
    }
  },
  "GET /billing/access-status": {
    "headers": {
      "Authorization": "Bearer <token>"
    },
    "response_200": {
      "access": "free|premium",
      "subscriptionStatus": "inactive|active|grace|pending",
      "plan": "monthly|family|null",
      "expiresAt": "ISO date or null"
    }
  }
}